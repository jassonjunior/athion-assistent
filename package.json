{
  "name": "athion-assistent",
  "version": "0.0.1",
  "private": true,
  "packageManager": "bun@1.3.9",
  "type": "module",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "test": "turbo run test",
    "test:core": "bun run packages/core/node_modules/.bin/vitest run --root packages/core",
    "test:core:coverage": "bun run packages/core/node_modules/.bin/vitest run --root packages/core --coverage",
    "bench": "bun run packages/core/scripts/benchmark.ts",
    "test:e2e:cli": "bun run packages/cli/node_modules/.bin/vitest run --root packages/cli --testPathPattern=e2e",
    "test:e2e:cli:model": "ATHION_E2E_MODEL=1 bun run packages/cli/node_modules/.bin/vitest run --root packages/cli --testPathPattern=e2e",
    "test:e2e:vscode": "cd packages/vscode && bunx wdio run e2e/wdio.conf.ts",
    "test:e2e:desktop": "cd packages/desktop && bunx wdio run e2e/wdio.conf.ts",
    "test:e2e:chatapp": "cd packages/test-ui && bunx playwright test e2e/",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "format": "prettier --write \"**/*.{ts,tsx,json,md,yml}\"",
    "prepare": "husky"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@rollup/rollup-darwin-arm64": "^4.59.0",
    "@types/bun": "^1.3.10",
    "@types/node": "^25.3.5",
    "eslint": "^10.0.3",
    "eslint-config-prettier": "^10.1.8",
    "husky": "^9.1.7",
    "lint-staged": "^16.3.2",
    "prettier": "^3.5.0",
    "turbo": "^2.4.0",
    "typescript": "^5.8.0",
    "typescript-eslint": "^8.56.1",
    "vitest": "^3.0.0"
  }
}
