    "format": "prettier --write \"**/*.{ts,tsx,json,md,yml}\""
  },
  "devDependencies": {
    "turbo": "^2.4.0",
    "typescript": "^5.8.0",
    "prettier": "^3.5.0",
    "vitest": "^3.0.0"
  }
}
