{
  "name": "@athion/cli",
  "version": "0.0.2",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "athion": "./dist/index.js"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "test": "vitest run",
    "test:e2e": "vitest run --testPathPattern='e2e'",
    "test:e2e:model": "ATHION_E2E_MODEL=1 vitest run --testPathPattern='e2e'",
    "lint": "eslint src/",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@athion/core": "workspace:*",
    "@athion/shared": "workspace:*",
    "ink": "^6.8.0",
    "ink-spinner": "^5.0.0",
    "ink-text-input": "^6.0.0",
    "react": "^19.2.4",
    "yargs": "^18.0.0"
  },
  "devDependencies": {
    "@types/react": "^19.2.14",
    "@types/yargs": "^17.0.35"
  }
}
