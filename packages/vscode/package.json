{
  "name": "athion-assistent",
  "displayName": "Athion Assistent",
  "description": "AI coding assistant with orchestrator + subagents",
  "version": "0.0.8",
  "publisher": "athion",
  "license": "MIT",
  "icon": "image.png",
  "repository": {
    "type": "git",
    "url": "https://github.com/jassonjunior/athion-assistent"
  },
  "keywords": [
    "ai",
    "coding",
    "assistant",
    "llm",
    "autocomplete"
  ],
  "engines": {
    "vscode": "^1.100.0"
  },
  "categories": [
    "AI",
    "Programming Languages"
  ],
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./dist/extension.js",
  "scripts": {
    "build": "bun esbuild.config.mjs && bun esbuild.webview.mjs",
    "build:ext": "bun esbuild.config.mjs",
    "build:webview": "bun esbuild.webview.mjs",
    "dev": "bun esbuild.config.mjs --watch",
    "test": "vitest run",
    "lint": "eslint src/",
    "typecheck": "tsc --noEmit",
    "package": "vsce package --no-dependencies",
    "publish": "vsce publish --no-dependencies",
    "test:e2e": "bunx wdio run e2e/wdio.conf.ts",
    "test:e2e:model": "ATHION_E2E_MODEL=1 bunx wdio run e2e/wdio.conf.ts"
  },
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "athion",
          "title": "Athion Assistent",
          "icon": "resources/icon.svg"
        }
      ]
    },
    "views": {
      "athion": [
        {
          "type": "webview",
          "id": "athion.chat",
          "name": "Chat"
        }
      ]
    },
    "commands": [
      {
        "command": "athion.newChat",
        "title": "Athion: New Chat"
      },
      {
        "command": "athion.abortChat",
        "title": "Athion: Abort Response"
      },
      {
        "command": "athion.focusChat",
        "title": "Athion: Focus Chat Panel"
      },
      {
        "command": "athion.explainCode",
        "title": "Athion: Explain Selection"
      },
      {
        "command": "athion.reviewCode",
        "title": "Athion: Review Selection"
      },
      {
        "command": "athion.refactorCode",
        "title": "Athion: Refactor Selection"
      },
      {
        "command": "athion.generateTests",
        "title": "Athion: Generate Tests"
      },
      {
        "command": "athion.fixBug",
        "title": "Athion: Fix Bug"
      },
      {
        "command": "athion.toggleInline",
        "title": "Athion: Toggle Inline Suggestions"
      },
      {
        "command": "athion.acceptDiff",
        "title": "Athion: Accept Change"
      },
      {
        "command": "athion.rejectDiff",
        "title": "Athion: Reject Change"
      },
      {
        "command": "athion.acceptAllDiffs",
        "title": "Athion: Accept All Changes"
      },
      {
        "command": "athion.rejectAllDiffs",
        "title": "Athion: Reject All Changes"
      },
      {
        "command": "athion.openSettings",
        "title": "Athion: Open Settings"
      },
      {
        "command": "athion.indexCodebase",
        "title": "Athion: Index Codebase"
      },
      {
        "command": "athion.searchCodebase",
        "title": "Athion: Search Codebase"
      }
    ],
    "keybindings": [
      {
        "command": "athion.newChat",
        "key": "ctrl+shift+a",
        "mac": "cmd+shift+a"
      },
      {
        "command": "athion.explainCode",
        "key": "ctrl+shift+e",
        "mac": "cmd+shift+e",
        "when": "editorHasSelection"
      },
      {
        "command": "athion.toggleInline",
        "key": "ctrl+shift+i",
        "mac": "cmd+shift+i"
      }
    ],
    "configuration": {
      "title": "Athion Assistent",
      "properties": {
        "athion.bunPath": {
          "type": "string",
          "default": "bun",
          "description": "Path to the Bun executable"
        },
        "athion.cliPath": {
          "type": "string",
          "default": "",
          "description": "Path to the @athion/cli entry point (index.ts). Leave empty to auto-detect from monorepo."
        },
        "athion.inlineEnabled": {
          "type": "boolean",
          "default": true,
          "description": "Enable inline code suggestions"
        }
      }
    }
  },
  "dependencies": {
    "@athion/shared": "workspace:*"
  },
  "devDependencies": {
    "@types/node": "^25.3.5",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@types/vscode": "^1.100.0",
    "@wdio/cli": "^9.0.0",
    "@wdio/json-reporter": "^9.0.0",
    "@wdio/local-runner": "^9.0.0",
    "@wdio/mocha-framework": "^9.0.0",
    "@wdio/spec-reporter": "^9.0.0",
    "esbuild": "^0.27.3",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "wdio-vscode-service": "^6.0.0",
    "webdriverio": "^9.0.0"
  }
}
