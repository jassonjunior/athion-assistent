{
  "name": "@athion/observability",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "concurrently \"bun run dev:server\" \"bun run dev:client\"",
    "dev:server": "bun --watch src/server/index.ts",
    "dev:client": "bun --bun node_modules/.bin/vite",
    "build": "bun --bun node_modules/.bin/vite build",
    "start": "bun src/server/index.ts",
    "test:e2e": "bunx playwright test e2e/",
    "test:e2e:model": "ATHION_E2E_MODEL=1 bunx playwright test e2e/",
    "playwright:install": "bunx playwright install chromium",
    "tauri": "tauri",
    "tauri:dev": "tauri dev",
    "tauri:build": "tauri build",
    "test:e2e:desktop": "bun test e2e/desktop/",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build"
  },
  "dependencies": {
    "@athion/core": "workspace:*",
    "@xyflow/react": "^12.6.0",
    "dagre": "^0.8.5",
    "react": "^19.1.0",
    "react-dom": "^19.1.0"
  },
  "devDependencies": {
    "@chromatic-com/storybook": "^5.0.1",
    "@playwright/test": "^1.50.0",
    "@storybook/addon-a11y": "^10.2.19",
    "@storybook/addon-docs": "^10.2.19",
    "@storybook/addon-onboarding": "^10.2.19",
    "@storybook/addon-vitest": "^10.2.19",
    "@storybook/react-vite": "^10.2.19",
    "@tauri-apps/cli": "^2",
    "@types/dagre": "^0.7.52",
    "@types/react": "^19.1.0",
    "@types/react-dom": "^19.1.0",
    "@types/ws": "^8.5.14",
    "@vitejs/plugin-react": "^4.5.2",
    "@vitest/browser": "^3.0.0",
    "@vitest/coverage-v8": "^3.0.0",
    "concurrently": "^9.1.0",
    "eslint-plugin-storybook": "^10.2.19",
    "playwright": "^1.58.2",
    "storybook": "^10.2.19",
    "typescript": "^5.8.0",
    "vite": "^6.3.0",
    "ws": "^8.18.0"
  }
}
