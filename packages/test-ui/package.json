{
  "name": "@athion/test-ui",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "concurrently \"bun run dev:server\" \"bun run dev:client\"",
    "dev:server": "bun --watch src/server/index.ts",
    "dev:client": "bun --bun node_modules/.bin/vite",
    "build": "bun --bun node_modules/.bin/vite build",
    "start": "bun src/server/index.ts",
    "test:e2e": "bunx playwright test e2e/",
    "test:e2e:model": "ATHION_E2E_MODEL=1 bunx playwright test e2e/",
    "playwright:install": "bunx playwright install chromium"
  },
  "dependencies": {
    "@athion/core": "workspace:*",
    "@xyflow/react": "^12.6.0",
    "dagre": "^0.8.5",
    "react": "^19.1.0",
    "react-dom": "^19.1.0"
  },
  "devDependencies": {
    "@types/dagre": "^0.7.52",
    "@types/react": "^19.1.0",
    "@types/react-dom": "^19.1.0",
    "@vitejs/plugin-react": "^4.5.2",
    "concurrently": "^9.1.0",
    "typescript": "^5.8.0",
    "vite": "^6.3.0",
    "@playwright/test": "^1.50.0",
    "ws": "^8.18.0",
    "@types/ws": "^8.5.14"
  }
}
